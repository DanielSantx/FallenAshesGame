--- !u!114 &689283021
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 689283017}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c2100396eb198bc49bc31a128712cc47, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  npcName: "Guardi\xE1n del Portal"
  dialogueLines:
  - "Ni un paso m\xE1s."
  - El portal permanece sellado por orden directa del Rey Aldrich.
  - "Si tuvieras permiso para pasar, lo sabr\xEDas. Ve a hablar con el Rey antes
    de acercarte aqu\xED."
  hasConditionalDialogue: 1
  dialogueLinesAfter:
  - "Vaya. El Rey te ha dado su bendici\xF3n."
  - "Pocos llegan hasta ese portal con vida. Menos a\xFAn vuelven."
  - "No s\xE9 si eres valiente o simplemente no tienes nada que perder."
  - "\u2026En cualquier caso, suerte. Algo me dice que la vas a necesitar."
  interactionRange: 2
  npcType: 
  interactPrompt: {fileID: 1552908886}
