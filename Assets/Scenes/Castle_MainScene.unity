  guard2Normal: {fileID: -3780885601876150589, guid: ba9abba2061281646ae337f53b8ff11e, type: 3}
  guard1Alert: {fileID: -5958318562550778127, guid: ba9abba2061281646ae337f53b8ff11e, type: 3}
  guard2Alert: {fileID: 5081362547143399631, guid: ba9abba2061281646ae337f53b8ff11e, type: 3}
  wallCollider: {fileID: 659047933}
  dialogueBeforeKing:
  - "Ni un paso m\xE1s."
  - El portal permanece sellado por orden directa del Rey Aldrich.
  - "Si tuvieras permiso para pasar, lo sabr\xEDas. Ve a hablar con el Rey antes
    de acercarte aqu\xED."
  dialogueAfterKing:
  - "Vaya. El Rey te ha dado su bendici\xF3n."
  - "Pocos llegan hasta ese portal con vida. Menos a\xFAn vuelven."
  - "No s\xE9 si eres valiente o simplemente no tienes nada que perder."
  - "\u2026En cualquier caso, suerte. Algo me dice que la vas a necesitar."
